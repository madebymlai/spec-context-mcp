# ==========================================================================
# Core Setup
# ==========================================================================

# Embeddings
EMBEDDING_PROVIDER=voyageai
EMBEDDING_API_KEY=
# Optional: leave empty to use provider default
EMBEDDING_MODEL=
EMBEDDING_RERANK_MODEL=rerank-2

# ChunkHound deep research (OpenRouter only)
OPENROUTER_API_KEY=
CHUNKHOUND_LLM_MODEL=google/gemini-2.5-flash

# Runtime settings (discipline, dispatch roles, models, reasoning effort,
# dashboard URL) are configured in the dashboard settings page.

# ==========================================================================
# Optional
# ==========================================================================

SPEC_CONTEXT_DISABLE_VERSION_CHECK=false

# EMBEDDING_BASE_URL=
# EMBEDDING_RERANK_URL=
# EMBEDDING_RERANK_FORMAT=auto
# EMBEDDING_RERANK_BATCH_SIZE=

# CHUNKHOUND_PYTHON=python3
# CHUNKHOUND_EMBED_SWEEP_SECONDS=300
# CHUNKHOUND_EMBED_SWEEP_BACKOFF_SECONDS=30
# CHUNKHOUND_FILE_QUEUE_MAXSIZE=2000
# CHUNKHOUND_FILE_QUEUE_DRAIN_SECONDS=1.0
